{
  "name": "@research-feed/ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx src/index.ts seed",
    "sync": "tsx src/index.ts sync",
    "retention": "tsx src/index.ts retention"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "fast-xml-parser": "^5.2.5",
    "pg": "^8.16.3",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  }
}
